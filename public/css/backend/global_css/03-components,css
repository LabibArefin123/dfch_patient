/*
|--------------------------------------------------------------------------
| HOVER BOX
|--------------------------------------------------------------------------
*/

.hover-box {
    display: inline-block;
    padding: 4px 6px;
    color: #000;
    text-decoration: none;
    transition: background-color 0.3s ease;
}


.hover-box:hover {
    background-color: #ff6b6b;
    color: #fff;
}


/*
|--------------------------------------------------------------------------
| CARD BODY
|--------------------------------------------------------------------------
*/

.card-body {
    overflow-x: auto;
}